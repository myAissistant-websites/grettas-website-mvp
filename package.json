{
    "name": "abdul-website",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "ddf-import": "tsx workers/ddf-importer.ts",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --no-warn-ignored"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@supabase/supabase-js": "^2.98.0",
        "dotenv": "^17.3.1",
        "framer-motion": "^12.34.3",
        "lucide-react": "^0.575.0",
        "maplibre-gl": "^4.7.1",
        "next": "16.1.6",
        "pg": "^8.13.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-map-gl": "^8.1.0",
        "resend": "^6.9.3",
        "server-only": "^0.0.1",
        "supercluster": "^8.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/pg": "^8.11.10",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/supercluster": "^7.1.3",
        "@vitejs/plugin-react": "^5.1.4",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "tailwindcss": "^4",
        "tsx": "^4.19.2",
        "typescript": "^5",
        "vitest": "^4.0.18"
    }
}
